<svg xmlns="http://www.w3.org/2000/svg" width="800" height="1200" viewBox="0 0 800 1200">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0f172a;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#1a2e50;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#162a4a;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#1a56db;stop-opacity:0.1" />
    </linearGradient>
  </defs>
  <rect width="800" height="1200" fill="url(#bg)"/>
  <!-- Decorative grid lines -->
  <g opacity="0.06" stroke="#fff" stroke-width="0.5">
    <line x1="100" y1="0" x2="100" y2="1200"/><line x1="200" y1="0" x2="200" y2="1200"/>
    <line x1="300" y1="0" x2="300" y2="1200"/><line x1="400" y1="0" x2="400" y2="1200"/>
    <line x1="500" y1="0" x2="500" y2="1200"/><line x1="600" y1="0" x2="600" y2="1200"/>
    <line x1="700" y1="0" x2="700" y2="1200"/>
    <line x1="0" y1="100" x2="800" y2="100"/><line x1="0" y1="200" x2="800" y2="200"/>
    <line x1="0" y1="300" x2="800" y2="300"/><line x1="0" y1="400" x2="800" y2="400"/>
    <line x1="0" y1="500" x2="800" y2="500"/><line x1="0" y1="600" x2="800" y2="600"/>
    <line x1="0" y1="700" x2="800" y2="700"/><line x1="0" y1="800" x2="800" y2="800"/>
    <line x1="0" y1="900" x2="800" y2="900"/><line x1="0" y1="1000" x2="800" y2="1000"/>
    <line x1="0" y1="1100" x2="800" y2="1100"/>
  </g>
  <!-- Decorative circles -->
  <circle cx="600" cy="300" r="180" fill="url(#accent)" opacity="0.4"/>
  <circle cx="150" cy="800" r="120" fill="url(#accent)" opacity="0.3"/>
  <circle cx="400" cy="550" r="60" fill="#3b82f6" opacity="0.08"/>
  <!-- Center text -->
  <text x="400" y="580" font-family="Inter, Arial, sans-serif" font-size="48" font-weight="700" fill="white" text-anchor="middle" opacity="0.15">NATANZ</text>
  <text x="400" y="620" font-family="Inter, Arial, sans-serif" font-size="16" fill="#94a3b8" text-anchor="middle" opacity="0.3" letter-spacing="4">CLOUD MANAGEMENT</text>
</svg>
